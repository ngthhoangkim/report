# SQL Server Configuration
# DB_AUTH_MODE:
# - sql: use DB_USER/DB_PASSWORD
# - windows: use Windows Authentication (requires msnodesqlv8, no DB_USER/DB_PASSWORD)
DB_AUTH_MODE=sql
DB_SERVER=your_server_address
DB_DATABASE=Hospital_NM

# SQL Authentication (used when DB_AUTH_MODE=sql)
DB_USER=your_username
DB_PASSWORD=your_password
DB_PORT=1433

DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Application Configuration
POLLING_INTERVAL_SECONDS=30
OUTPUT_FOLDER=./output
LOGS_FOLDER=./logs
# Log files: automation-YYYY-MM-DD.log, automation-error-YYYY-MM-DD.log (xoay theo ngày)
# automation-summary-YYYY-MM-DD.log — một dòng JSON / job automation (OK hoặc lỗi)
# LOG_MAX_FILES=30d
# LOG_MAX_SIZE=20m
# LOG_ZIP_OLD_LOGS=true
# LOG_AUTOMATION_SUMMARY=false
CHECKPOINT_FILE=./checkpoint.txt

# Worker (src/index.js): backfill N năm lùi từ hôm nay rồi POLLING_INTERVAL_SECONDS chạy mãi (chỉ khi checkpoint còn mặc định 1970, hoặc bật FORCE)
# AUTOMATION_INITIAL_BACKFILL_YEARS=3
# AUTOMATION_FORCE_BACKFILL=true
# BACKFILL_CONCURRENCY=2
# BACKFILL_DELAY_MS=0


USE_WORD=true

# Database table names
DATA_TABLE_NAME=YourDataTable
TEMPLATE_VIEW_NAME=viewImageFileName
IMAGING_RESULT_TABLE=CN_ImagingResultData

# Report Configuration
REPORT_ITEM_ID_COLUMN=ItemNum
REPORT_TEMPLATE_COLUMN=TemplateFile

PATHS_TEMPLATES=./template
PATHS_OUTPUT=./output/CDHA
PATHS_FALLBACK_IMAGE_DIR=./documents2
PATHS_LOCAL_IMAGE_DIR=./Documents
PRINTED_IMAGES_ONLY=true

# LibreOffice: code đã bỏ PYTHONHOME/PYTHONPATH khi gọi soffice (tránh stderr Python "<prefix>").
# Nếu vẫn thấy, kiểm tra cài đặt LO hoặc unset tay trước khi chạy: unset PYTHONHOME PYTHONPATH

# Script download CN_FILES: mặc định khớp CR_Session.Id HOẶC CR_SubSession.Id; ép một kiểu:
# CN_FILES_SESSION_ID_MATCHES=cr_session
# CN_FILES_SESSION_ID_MATCHES=subsession

# Gộp ảnh từ dbo.CN_FILES (cùng FileNum + SessionId) khi ghép báo cáo CDHA — bổ sung nguồn ngoài CN_ImagingResult.FileName
# REPORT_MERGE_CN_FILES_MEDIA=false

# Mật khẩu giải nén ZIP lấy từ CN_FILES (ZipCrypto qua adm-zip; AES có thể không hỗ trợ)
# CN_FILES_ZIP_PASSWORD=ABAKI_HOCMON00

# Ảnh CN_FILES: last = chỉ segment PDF cuối phiên | match = theo từ khóa ECG/PAP... | last_or_match | all | never
# REPORT_CN_FILES_ATTACH_MODE=last
# REPORT_CN_FILES_ATTACH_KEYWORDS=ecg,pap,điện tim,dien tim,rest-ecg

# Ảnh CN_FILES không có Printed: chỉ append khi segment được phép (theo mode trên)
# REPORT_APPEND_UNMATCHED_CN_FILES_IMAGES=false

# Test full luồng PDF: npm run test:report -- 26003528 844466

# RTF → plain (fallback PDF): ưu tiên LibreOffice .txt — tắt nếu chỉ dùng stripper
# RTF_PLAIN_USE_LIBREOFFICE=false

# Decode RTF sau gunzip: mặc định nhận \\ansicpg / CP1258 (Aspose trên server parse RTF; C# chỉ UTF-8 string)
# Ép giống GzipHelper C# thuần (có thể lại lỗi ?/ nếu blob là ANSI): RTF_FORCE_UTF8=true
# Tắt thử 1258 khi đã chắc UTF-8: RTF_TRY_WIN1258_FALLBACK=false
# Ghi RTF inject: utf8 (mặc định, không BOM) | utf8_bom | utf16le
# RTF_WRITE_ENCODING=utf8_bom
# RTF_WRITE_UTF8_BOM=false
# Log gzip/độ dài/preview sau decompress (debug): REPORT_LOG_RTF_META=true


PACS_MERGE_PDF=true
PACS_FETCH_TIMEOUT_MS=45000

# Backfill + upload S3 (scripts/backfillGenerateAndUpload.js)
# S3_UPLOAD_API_BASE=https://dsbiy10xl4.execute-api.ap-southeast-1.amazonaws.com
# S3_UPLOAD_PREFIX=khambenh/
# BACKFILL_CONCURRENCY=2
# BACKFILL_DELAY_MS=0
# Thử nhanh trên AWS: lùi N ngày từ bây giờ (chỉ khi không truyền --from / --days / --years trên CLI)
# BACKFILL_DAYS=3

# Sau inject RTF: mặc định giữ căn tiêu đề như RTF/template; chỉ ép căn PHẢI dòng BS.
# Căn PHẢI đoạn có "Bác sĩ chỉ định" / <<ReferDoctor>> (mặc định bật, không cần REPORT_ALIGN_CLOSING_BLOCK)
# REPORT_ALIGN_REFER_DOCTOR_LINES=false
# REPORT_ALIGN_CLOSING_BLOCK=false
# REPORT_ALIGN_DOCTOR_RIGHT=false
# Dòng chỉ có ngày dạng dd/mm/yyyy: căn phải cùng hàng chữ ký (mặc định true)
# REPORT_ALIGN_DATE_RIGHT=false
# Ép tiêu đề/ ngày thành một kiểu: preserve (mặc định) | center | both | left
# REPORT_CLOSING_HEADING_JC=preserve

# Sau khi chèn RTF (LibreOffice): bỏ đoạn trống thừa đầu/cuối và gộp nhiều <w:p> rỗng liên tiếp (giảm khoảng trắng dọc trên PDF)
# REPORT_SANITIZE_RTF_WHITESPACE=false
# REPORT_RTF_MAX_CONSECUTIVE_EMPTY_PARAS=2

# Chuẩn hóa placeholder ảnh ___IMG_n___ (3 gạch) → __IMG_n__ trong docx
# REPORT_NORMALIZE_IMG_TOKENS=false
