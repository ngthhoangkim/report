# SQL Server Configuration
# DB_AUTH_MODE:
# - sql: use DB_USER/DB_PASSWORD
# - windows: use Windows Authentication (requires msnodesqlv8, no DB_USER/DB_PASSWORD)
DB_AUTH_MODE=sql
DB_SERVER=your_server_address
DB_DATABASE=Hospital_NM

# SQL Authentication (used when DB_AUTH_MODE=sql)
DB_USER=your_username
DB_PASSWORD=your_password
DB_PORT=1433

DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Application Configuration
POLLING_INTERVAL_SECONDS=30
OUTPUT_FOLDER=./output
LOGS_FOLDER=./logs
CHECKPOINT_FILE=./checkpoint.txt


USE_WORD=true
# Optional: path powershell.exe nếu môi trường đặc biệt
# POWERSHELL_EXE=C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe
# Optional: set soffice path khi cần (macOS/Linux hoặc Windows nếu USE_WORD=false)
# SOFFICE_PATH=C:\\Program Files\\LibreOffice\\program\\soffice.exe

# Database table names
DATA_TABLE_NAME=YourDataTable
TEMPLATE_VIEW_NAME=viewImageFileName
IMAGING_RESULT_TABLE=CN_ImagingResultData

# Report Configuration
REPORT_ITEM_ID_COLUMN=ItemNum
REPORT_TEMPLATE_COLUMN=TemplateFile

PATHS_TEMPLATES=./template
# Optional: logo.jpg / logo.jpeg / logo.png cùng thư mục PATHS_TEMPLATES (đúng path env; mặc định ./template khác ./Templates trên Linux/macOS).
PATHS_OUTPUT=./output/CDHA
PATHS_FALLBACK_IMAGE_DIR=./documents2
PATHS_LOCAL_IMAGE_DIR=./Documents
PRINTED_IMAGES_ONLY=true